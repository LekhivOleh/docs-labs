@model docs_project.Domain.Entities.User

<h1>User Details</h1>

<p><strong>Id:</strong> @Model.Id</p>
<p><strong>Username:</strong> @Model.Username</p>
<p><strong>Email:</strong> @Model.Email</p>

<h2>Chats</h2>
<ul>
    @foreach (var chat in Model.Chats)
    {
        <li>
            <a asp-controller="ChatsMvc" asp-action="Details" asp-route-id="@chat.Id">@chat.Id</a>
        </li>
    }
</ul>

<p><a asp-action="Index">Back</a></p>

